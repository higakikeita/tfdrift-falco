# Multi-stage build for mock Falco server

FROM golang:1.26-alpine AS builder

RUN apk add --no-cache git make gcc musl-dev

WORKDIR /build

# Copy go mod files from project root
COPY ../../go.mod ../../go.sum ./

RUN go mod download

# Copy mock server source
COPY mock_falco_server.go .

# Build binary
RUN CGO_ENABLED=0 GOOS=linux go build \
    -a -installsuffix cgo \
    -o mock-falco-server \
    ./mock_falco_server.go

FROM alpine:3.23.3

RUN apk add --no-cache ca-certificates tzdata wget

COPY --from=builder /build/mock-falco-server /usr/local/bin/

EXPOSE 5060 8081

HEALTHCHECK --interval=5s --timeout=3s --start-period=5s --retries=3 \
    CMD wget --no-verbose --tries=1 --spider http://localhost:8081/health || exit 1

ENTRYPOINT ["/usr/local/bin/mock-falco-server"]
CMD ["--grpc-port", "5060", "--http-port", "8081"]
