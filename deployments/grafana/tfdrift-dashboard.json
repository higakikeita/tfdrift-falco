{
  "annotations": {
    "list": []
  },
  "description": "TFDrift-Falco: Multi-Cloud Terraform Drift Detection Dashboard",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "links": [],
  "panels": [
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 1,
      "title": "Provider Overview",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "mappings": [
            { "options": { "0": { "color": "red", "text": "Down" }, "1": { "color": "green", "text": "Healthy" } }, "type": "value" }
          ],
          "thresholds": { "steps": [{ "color": "red", "value": null }, { "color": "green", "value": 1 }] }
        }
      },
      "gridPos": { "h": 4, "w": 8, "x": 0, "y": 1 },
      "id": 2,
      "options": { "colorMode": "background", "graphMode": "none", "justifyMode": "auto", "orientation": "auto", "reduceOptions": { "calcs": ["lastNotNull"] }, "textMode": "auto" },
      "title": "AWS Provider",
      "type": "stat",
      "targets": [{ "expr": "tfdrift_component_status{component=\"aws\"}", "legendFormat": "AWS" }]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "mappings": [
            { "options": { "0": { "color": "red", "text": "Down" }, "1": { "color": "green", "text": "Healthy" } }, "type": "value" }
          ],
          "thresholds": { "steps": [{ "color": "red", "value": null }, { "color": "green", "value": 1 }] }
        }
      },
      "gridPos": { "h": 4, "w": 8, "x": 8, "y": 1 },
      "id": 3,
      "options": { "colorMode": "background", "graphMode": "none", "justifyMode": "auto", "orientation": "auto", "reduceOptions": { "calcs": ["lastNotNull"] }, "textMode": "auto" },
      "title": "GCP Provider",
      "type": "stat",
      "targets": [{ "expr": "tfdrift_component_status{component=\"gcp\"}", "legendFormat": "GCP" }]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "mappings": [
            { "options": { "0": { "color": "red", "text": "Down" }, "1": { "color": "green", "text": "Healthy" } }, "type": "value" }
          ],
          "thresholds": { "steps": [{ "color": "red", "value": null }, { "color": "green", "value": 1 }] }
        }
      },
      "gridPos": { "h": 4, "w": 8, "x": 16, "y": 1 },
      "id": 4,
      "options": { "colorMode": "background", "graphMode": "none", "justifyMode": "auto", "orientation": "auto", "reduceOptions": { "calcs": ["lastNotNull"] }, "textMode": "auto" },
      "title": "Azure Provider",
      "type": "stat",
      "targets": [{ "expr": "tfdrift_component_status{component=\"azure\"}", "legendFormat": "Azure" }]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 5 },
      "id": 10,
      "title": "Drift Alerts",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "axisBorderShow": false, "drawStyle": "line", "fillOpacity": 20, "lineWidth": 2, "pointSize": 5, "showPoints": "auto", "stacking": { "mode": "normal" } }
        },
        "overrides": [
          { "matcher": { "id": "byName", "options": "aws" }, "properties": [{ "id": "color", "value": { "fixedColor": "#FF9900", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "gcp" }, "properties": [{ "id": "color", "value": { "fixedColor": "#4285F4", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "azure" }, "properties": [{ "id": "color", "value": { "fixedColor": "#0078D4", "mode": "fixed" } }] }
        ]
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 6 },
      "id": 11,
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "title": "Drift Alerts by Provider (Rate)",
      "type": "timeseries",
      "targets": [{ "expr": "rate(tfdrift_drift_alerts_total[5m])", "legendFormat": "{{provider}}" }]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "axisBorderShow": false, "drawStyle": "bars", "fillOpacity": 80, "lineWidth": 1, "stacking": { "mode": "normal" } }
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 6 },
      "id": 12,
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "title": "Drift Alerts by Severity",
      "type": "timeseries",
      "targets": [
        { "expr": "rate(tfdrift_drift_alerts_total{severity=\"critical\"}[5m])", "legendFormat": "Critical" },
        { "expr": "rate(tfdrift_drift_alerts_total{severity=\"high\"}[5m])", "legendFormat": "High" },
        { "expr": "rate(tfdrift_drift_alerts_total{severity=\"medium\"}[5m])", "legendFormat": "Medium" },
        { "expr": "rate(tfdrift_drift_alerts_total{severity=\"low\"}[5m])", "legendFormat": "Low" }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 5 }, { "color": "red", "value": 10 }] }
        }
      },
      "gridPos": { "h": 4, "w": 8, "x": 0, "y": 14 },
      "id": 13,
      "options": { "colorMode": "background", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "title": "Unresolved Alerts (Total)",
      "type": "stat",
      "targets": [{ "expr": "sum(tfdrift_unresolved_alerts)", "legendFormat": "Unresolved" }]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": { "unit": "s", "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 30 }, { "color": "red", "value": 120 }] } }
      },
      "gridPos": { "h": 4, "w": 8, "x": 8, "y": 14 },
      "id": 14,
      "options": { "colorMode": "value", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "title": "Detection Latency (p95)",
      "type": "stat",
      "targets": [{ "expr": "histogram_quantile(0.95, rate(tfdrift_detection_latency_seconds_bucket[5m]))", "legendFormat": "p95" }]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": { "unit": "short", "thresholds": { "steps": [{ "color": "green", "value": null }] } }
      },
      "gridPos": { "h": 4, "w": 8, "x": 16, "y": 14 },
      "id": 15,
      "options": { "colorMode": "value", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "title": "Events Processed (Total)",
      "type": "stat",
      "targets": [{ "expr": "sum(tfdrift_events_processed_total)", "legendFormat": "Total" }]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 18 },
      "id": 20,
      "title": "Events Processing",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "drawStyle": "line", "fillOpacity": 10, "lineWidth": 2, "pointSize": 5, "showPoints": "auto" }
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 19 },
      "id": 21,
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "title": "Events Processed by Source (Rate)",
      "type": "timeseries",
      "targets": [{ "expr": "rate(tfdrift_events_processed_total[5m])", "legendFormat": "{{source}} ({{status}})" }]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": { "custom": { "drawStyle": "line", "fillOpacity": 10, "lineWidth": 2 } }
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 19 },
      "id": 22,
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "title": "Top Drifted Resource Types",
      "type": "timeseries",
      "targets": [{ "expr": "topk(10, sum by (resource_type) (tfdrift_drift_alerts_total))", "legendFormat": "{{resource_type}}" }]
    }
  ],
  "schemaVersion": 39,
  "tags": ["tfdrift", "terraform", "drift-detection", "multi-cloud"],
  "templating": {
    "list": [
      {
        "current": { "selected": false, "text": "Prometheus", "value": "Prometheus" },
        "hide": 0,
        "includeAll": false,
        "name": "DS_PROMETHEUS",
        "options": [],
        "query": "prometheus",
        "type": "datasource"
      }
    ]
  },
  "time": { "from": "now-1h", "to": "now" },
  "title": "TFDrift-Falco Multi-Cloud Dashboard",
  "uid": "tfdrift-falco-multicloud",
  "version": 1
}
